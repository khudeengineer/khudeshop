---
const year = new Date().getFullYear();
---
<footer class="bg-slate-900 text-white pt-20 pb-10 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="col-span-1 md:col-span-1">
        <div class="flex items-center gap-2 mb-6">
          <div class="w-8 h-8 bg-brand-blue rounded-lg flex items-center justify-center text-white font-bold text-lg">K</div>
          <span class="text-xl font-bold tracking-tight">ক্ষুদে শপ</span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed mb-6">
          আমরা মাইক্রোকন্ট্রোলার, IoT এবং রোবোটিক্স প্রোডাক্টের মাধ্যমে প্রযুক্তির জয়যাত্রা নিশ্চিত করতে কাজ করছি।
        </p>
        <div class="flex space-x-4">
          <a href="#" class="w-10 h-10 bg-slate-800 rounded-full flex items-center justify-center hover:bg-brand-blue transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 bg-slate-800 rounded-full flex items-center justify-center hover:bg-brand-blue transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="col-span-1">
        <h3 class="text-lg font-bold mb-6">কুইক লিঙ্ক</h3>
        <ul class="space-y-4 text-slate-400 text-sm">
          <li><a href="/" class="hover:text-brand-blue transition-colors">হোম</a></li>
          <li><a href="/products" class="hover:text-brand-blue transition-colors">সব প্রোডাক্টস</a></li>
          <li><a href="/about" class="hover:text-brand-blue transition-colors">আমাদের সম্পর্কে</a></li>
          <li><a href="/contact" class="hover:text-brand-blue transition-colors">যোগাযোগ</a></li>
        </ul>
      </div>

      <!-- Categories -->
      <div class="col-span-1">
        <h3 class="text-lg font-bold mb-6">ক্যাটাগরি</h3>
        <ul class="space-y-4 text-slate-400 text-sm">
          <li><a href="/products?category=Robot%20Kits" class="hover:text-brand-blue transition-colors">রোবট কিটস</a></li>
          <li><a href="/products?category=Sensors" class="hover:text-brand-blue transition-colors">সেন্সর</a></li>
          <li><a href="/products?category=Microcontrollers" class="hover:text-brand-blue transition-colors">মাইক্রোকন্ট্রোলার</a></li>
          <li><a href="/products?category=Components" class="hover:text-brand-blue transition-colors">ইলেক্ট্রনিক্স পার্টস</a></li>
        </ul>
      </div>

      <!-- Newsletter/Contact Info -->
      <div class="col-span-1">
        <h3 class="text-lg font-bold mb-6">হেড অফিস</h3>
        <ul class="space-y-4 text-slate-400 text-sm">
          <li class="flex items-start gap-3">
             <svg class="w-5 h-5 text-brand-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
             <span>ঢাকা, বাংলাদেশ</span>
          </li>
          <li class="flex items-start gap-3">
             <svg class="w-5 h-5 text-brand-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
             <span>+৮৮০ ১৭৩৬০০৯৩২৪</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-slate-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-slate-500">&copy; {year} ক্ষুদে শপ. সর্বস্বত্ব সংরক্ষিত।</p>
      <div class="flex space-x-6 text-sm text-slate-500">
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
