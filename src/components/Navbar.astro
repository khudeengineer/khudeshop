---
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const searchData = allProducts.map(p => ({
  id: p.id,
  title: p.data.title,
  category: p.data.category,
  price: p.data.price,
  image: p.data.image
}));
---
<header class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-lg shadow-sm fixed w-full z-50 top-0 border-b border-slate-100 dark:border-slate-800 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 md:h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-10 h-10 bg-brand-blue rounded-xl flex items-center justify-center text-white font-bold text-xl group-hover:rotate-12 transition-transform">K</div>
          <span class="text-2xl font-extrabold text-slate-900 dark:text-white tracking-tight">ক্ষুদে <span class="text-brand-blue">শপ</span></span>
        </a>
      </div>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center space-x-8">
        <a href="/" class="text-slate-600 dark:text-slate-300 hover:text-brand-blue dark:hover:text-brand-blue font-semibold transition-all hover:scale-105">হোম</a>
        <a href="/products" class="text-slate-600 dark:text-slate-300 hover:text-brand-blue dark:hover:text-brand-blue font-semibold transition-all hover:scale-105">প্রোডাক্টস</a>
        <a href="/about" class="text-slate-600 dark:text-slate-300 hover:text-brand-blue dark:hover:text-brand-blue font-semibold transition-all hover:scale-105">আমাদের সম্পর্কে</a>
        <a href="/contact" class="text-slate-600 dark:text-slate-300 hover:text-brand-blue dark:hover:text-brand-blue font-semibold transition-all hover:scale-105">যোগাযোগ</a>
      </nav>

      <!-- Search, Theme & Cart -->
      <div class="flex items-center space-x-3 md:space-x-5">
        <!-- Search -->
        <div class="relative hidden sm:block">
          <div class="relative">
             <input 
              type="text" 
              id="global-search" 
              placeholder="প্রোডাক্ট খুঁজুন..." 
              class="w-48 lg:w-64 bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white text-sm rounded-xl py-2 px-4 pl-10 focus:outline-none focus:ring-2 focus:ring-brand-blue transition-all"
            />
            <svg class="w-4 h-4 text-slate-400 absolute left-3 top-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          
          <!-- Search Results Dropdown -->
          <div id="search-results" class="hidden absolute top-full mt-2 left-0 w-80 bg-white dark:bg-slate-800 rounded-2xl shadow-2xl border border-slate-100 dark:border-slate-700 overflow-hidden z-50 animate-in fade-in slide-in-from-top-2 duration-200">
             <div id="search-results-list" class="max-h-[70vh] overflow-y-auto p-2">
                <!-- Results rendered via JS -->
             </div>
          </div>
        </div>

        <!-- Theme Toggle -->
        <button id="theme-toggle" class="p-2.5 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors" title="Toggle Theme">
          <svg id="theme-icon-sun" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M16.5 12a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"></path></svg>
          <svg id="theme-icon-moon" class="w-5 h-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
        </button>

        <a href="/cart" class="relative group p-2.5 rounded-xl bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all active:scale-95">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-700 dark:text-slate-300 group-hover:text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <span id="cart-counter" class="absolute -top-1 -right-1 bg-brand-green text-white text-[10px] font-bold rounded-full h-5 w-5 flex items-center justify-center border-2 border-white dark:border-slate-800 transition-all group-hover:scale-110">0</span>
        </a>
        
        <button id="mobile-menu-btn" class="lg:hidden p-2.5 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden absolute top-full left-0 w-full bg-white dark:bg-slate-900 border-b border-slate-100 dark:border-slate-800 shadow-xl animate-in slide-in-from-top duration-300 z-40">
    <div class="px-4 py-8 space-y-6">
      <div class="relative sm:hidden mb-6">
        <input 
          type="text" 
          id="mobile-search" 
          placeholder="প্রোডাক্ট খুঁজুন..." 
          class="w-full bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white rounded-xl py-3 px-10 focus:outline-none focus:ring-2 focus:ring-brand-blue"
        />
        <svg class="w-5 h-5 text-slate-400 absolute left-3 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
      <a href="/" class="block text-xl font-bold text-slate-800 dark:text-white hover:text-brand-blue px-4">হোম</a>
      <a href="/products" class="block text-xl font-bold text-slate-800 dark:text-white hover:text-brand-blue px-4">প্রোডাক্টস</a>
      <a href="/about" class="block text-xl font-bold text-slate-800 dark:text-white hover:text-brand-blue px-4">আমাদের সম্পর্কে</a>
      <a href="/contact" class="block text-xl font-bold text-slate-800 dark:text-white hover:text-brand-blue px-4">যোগাযোগ</a>
    </div>
  </div>

  <!-- Search Data Injection -->
  <script is:inline id="search-data" type="application/json" set:html={JSON.stringify(searchData)} />
</header>
