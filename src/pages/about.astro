---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="আমাদের সম্পর্কে" description="ক্ষুদে শপ সম্পর্কে বিস্তারিত জানুন। আমাদের মিশন ও ভিশন।">
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-brand-blue/5 dark:bg-brand-blue/10 -z-10"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold mb-6 gradient-text">ক্ষুদে শপ - আপনার টেক শপ</h1>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        ক্ষুদে শপ একটি আধুনিক ই-কমার্স প্ল্যাটফর্ম যেখানে আপনি পাচ্ছেন মাইক্রোকন্ট্রোলার, IoT, রোবোটিক্স এবং বিভিন্ন আইটি প্রোডাক্ট। আমরা মানসম্মত পণ্য ও দ্রুত ডেলিভারি নিশ্চিত করতে বদ্ধপরিকর।
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl font-bold mb-6 dark:text-white">আমাদের লক্ষ্য</h2>
        <p class="text-lg text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
          আমাদের লক্ষ্য হলো সাশ্রীয় মূল্যে গুণগত মানসম্পন্ন প্রযুক্তি পণ্য সবার কাছে পৌঁছে দেওয়া। গ্রাহকের সন্তুষ্টি আমাদের মূল অনুপ্রেরণা।
        </p>
        <div class="space-y-4">
          <div class="flex items-start">
            <div class="flex-shrink-0 bg-brand-green/10 p-2 rounded-lg text-brand-green">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
            </div>
            <p class="ml-4 text-slate-700 dark:text-slate-300">সহজবোধ্য টিউটোরিয়াল ও সাপোর্ট</p>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0 bg-brand-green/10 dark:bg-brand-green/20 p-2 rounded-lg text-brand-green">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
            </div>
            <p class="ml-4 text-slate-700 dark:text-slate-300">সাশ্রয়ী মূল্যে অরিজিনাল পার্টস</p>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0 bg-brand-green/10 dark:bg-brand-green/20 p-2 rounded-lg text-brand-green">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
            </div>
            <p class="ml-4 text-slate-700 dark:text-slate-300">উদ্ভাবনী প্রকল্পের জন্য গাইডলাইন</p>
          </div>
        </div>
      </div>
      <div class="bg-gradient-to-br from-brand-blue to-teal-500 rounded-3xl aspect-video shadow-2xl flex items-center justify-center text-white text-4xl font-bold animate-float">
        Future Engineers
      </div>
    </div>
  </section>
</BaseLayout>
