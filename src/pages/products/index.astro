---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { getCollection } from "astro:content";

const allProducts = await getCollection("products");
const sortedProducts = allProducts.sort(
  (a, b) =>
    new Date(b.data.dateAdded).getTime() - new Date(a.data.dateAdded).getTime(),
);

const totalProducts = sortedProducts.length;
const pageSize = 8;
const lastPage = Math.ceil(totalProducts / pageSize);
const products = sortedProducts.slice(0, pageSize);
const categories = [
  ...new Set(allProducts.map((p) => p.data.category.replace(/"/g, "").trim())),
];

const page = {
  currentPage: 1,
  lastPage,
  total: totalProducts,
  url: {
    prev: null,
    next: lastPage > 1 ? "/products/2" : null,
  },
};
---

<BaseLayout title="সব প্রোডাক্টস">
  <!-- Header -->
  <section
    class="bg-slate-50 dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 py-16 transition-colors"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1
          class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-6"
        >
          সব প্রোডাক্টস
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 font-medium">
          আপনার প্রজেক্টের জন্য সেরা রোবটিক্স পার্টস ও লার্নিং কিটস খুঁজে নিন।
          হাই-কোয়ালিটি এবং ১০০% অরিজিনাল পার্টসের নিশ্চয়তা।
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Filter Controls -->
    <div
      class="flex flex-col md:flex-row md:items-center justify-between gap-8 mb-16"
    >
      <div class="flex flex-wrap items-center gap-3">
        <a
          href="/products"
          class="px-6 py-2.5 rounded-xl border-2 font-bold text-sm transition-all active bg-brand-blue text-white border-brand-blue shadow-lg shadow-brand-blue/20 -translate-y-0.5"
          >সব</a
        >
        <a
          href="/products/offer"
          class="px-6 py-2.5 rounded-xl border-2 font-bold text-sm transition-all border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:border-brand-blue hover:text-brand-blue"
          >ধামাকা অফার</a
        >
        <a
          href="/products/top"
          class="px-6 py-2.5 rounded-xl border-2 font-bold text-sm transition-all border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:border-brand-blue hover:text-brand-blue"
          >টপ রেটেড</a
        >
        <div class="h-8 w-px bg-slate-200 dark:bg-slate-700 hidden md:block">
        </div>
        {
          categories.map((cat) => (
            <a
              href={`/products/${cat}`}
              class="px-6 py-2.5 rounded-xl border-2 font-bold text-sm transition-all border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:border-brand-blue hover:text-brand-blue"
            >
              {cat}
            </a>
          ))
        }
      </div>

      <div
        class="text-sm font-bold text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-4 py-2 rounded-lg"
      >
        পেজ 1 / {lastPage} (মোট <span class="text-brand-blue"
          >{totalProducts}</span
        > টি প্রোডাক্ট)
      </div>
    </div>

    <!-- Product Grid -->
    <div
      id="product-grid"
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10"
    >
      {
        products.map((product) => (
          <div class="product-item animate-in fade-in zoom-in duration-500">
            <ProductCard product={product} />
          </div>
        ))
      }
    </div>

    <!-- Pagination Navigation -->
    {
      lastPage > 1 && (
        <nav class="mt-20 flex justify-center items-center gap-2">
          <span class="flex items-center justify-center w-12 h-12 rounded-xl border-2 border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-slate-300 dark:text-slate-700 cursor-not-allowed">
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"
              />
            </svg>
          </span>

          <div class="flex items-center gap-2 px-4 py-2 bg-slate-100 dark:bg-slate-800 rounded-2xl">
            <span class="text-sm font-bold text-slate-900 dark:text-white">
              পেজ 1
            </span>
            <span class="text-slate-400">/</span>
            <span class="text-sm font-bold text-slate-500">{lastPage}</span>
          </div>

          {page.url.next && (
            <a
              href={page.url.next}
              class="flex items-center justify-center w-12 h-12 rounded-xl border-2 border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:border-brand-blue hover:text-brand-blue transition-all"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          )}
        </nav>
      )
    }
  </div>
</BaseLayout>
